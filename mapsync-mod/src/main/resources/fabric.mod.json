{
	"schemaVersion": 1,
	"id": "mapsync",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "${mod_description}",
	"authors": "%FABRIC_AUTHORS_ARRAY%",
	"contact": {
		"homepage": "${mod_home_url}",
		"sources": "${mod_source_url}",
		"issues": "${mod_issues_url}"
	},
	"license": "${copyright_licence}",
	"icon": "assets/mapsync/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"gjum.minecraft.mapsync.mod.MapSyncMod"
		],
		"modmenu": [
			"gjum.minecraft.mapsync.mod.integrations.modmenu.ModMenuIntegration"
		]
	},
	"depends": {
		"minecraft": "${minecraft_version}",
		"fabricloader": ">=${fabric_loader_version}",
		"fabric": "*"
	},
	"suggests": {
		"modmenu": "*",
		"voxelmap": "*",
		"journeymap": "*",
		"xaeroworldmap": "*"
	},
	"mixins": [
		"mapsync.mixins.json"
	]
}
